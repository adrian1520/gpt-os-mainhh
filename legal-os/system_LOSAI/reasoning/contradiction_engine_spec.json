{
  "engine": "contradiction_engine_v1",
  "description": "Detects contradictions between normalized facts",
  "input": "facts/facts.json",
  "output": "analysis/contradictions.json",
  "comparison_fields": [
    "subject",
    "statement_normalized",
    "actors",
    "date"
  ],
  "contradiction_types": {
    "statement_conflict": {
      "rule": "same subject + opposite polarity",
      "severity": "HIGH"
    },
    "timeline_conflict": {
      "rule": "same event + conflicting dates",
      "severity": "MEDIUM"
    },
    "source_conflict": {
      "rule": "different sources + conflicting statements",
      "severity": "HIGH"
    },
    "self_conflict": {
      "rule": "same source + contradictory statements over time",
      "severity": "CRITICAL"
    }
  },
  "scoring": {
    "HIGH": 0.9,
    "MEDIUM": 0.6,
    "LOW": 0.3,
    "CRITICAL": 1.0
  },
  "output_schema": {
    "contradiction_id": "string",
    "fact_A": "fact_id",
    "fact_B": "fact_id",
    "type": "string",
    "severity": "string",
    "confidence": "float",
    "explanation": "string",
    "recommended_action": "string"
  }
}